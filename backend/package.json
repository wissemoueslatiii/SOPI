{
  "name": "sopi-backend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prod": "npm run build && npm start",
    "docker:build": "docker build -f ../Dockerfile.backend -t sopi-backend:latest ..",
    "docker:run": "docker run -p 4000:4000 --env-file .env sopi-backend:latest"
  },
  "dependencies": {
    "@google/genai": "^1.39.0",
    "@supabase/supabase-js": "^2.95.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "typescript": "~5.8.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "tsx": "^4.19.0"
  }
}
